@{
    ViewData["Title"] = "تعديل مورد";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var s = (SuperMarket.Models.Supplier)Model;
}

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="/Suppliers" class="btn btn-sm btn-outline-secondary">→ رجوع</a>
    <h5 class="mb-0">تعديل بيانات المورد</h5>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form method="post" action="/Suppliers/EditSave">
            <input type="hidden" name="Id" value="@s.Id">
            <input type="hidden" name="CreatedAt" value="@s.CreatedAt.ToString("o")">
            <div class="mb-3">
                <label class="form-label">اسم المورد <span class="text-danger">*</span></label>
                <input type="text" name="Name" class="form-control" value="@s.Name" required>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">الهاتف</label>
                    <input type="text" name="Phone" class="form-control" value="@s.Phone">
                </div>
                <div class="col-md-6">
                    <label class="form-label">البريد الإلكتروني</label>
                    <input type="email" name="Email" class="form-control" value="@s.Email">
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">العنوان</label>
                <input type="text" name="Address" class="form-control" value="@s.Address">
            </div>
            <div class="mb-3">
                <label class="form-label">الرقم الضريبي</label>
                <input type="text" name="TaxNumber" class="form-control" value="@s.TaxNumber">
            </div>
            <div class="mb-3 form-check">
                <input type="checkbox" name="IsActive" value="true" class="form-check-input" id="isActive" @(s.IsActive ? "checked" : "")>
                <label class="form-check-label" for="isActive">نشط</label>
            </div>
            <button type="submit" class="btn btn-success px-4">حفظ التعديلات</button>
        </form>
    </div>
</div>
