@model List<SuperMarket.Models.PurchaseOrder>
@{
    ViewData["Title"] = "أوامر الشراء";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">📋 أوامر الشراء</h5>
    <a href="/Suppliers" class="btn btn-sm btn-outline-secondary">→ الموردين</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>رقم الأمر</th><th>المورد</th><th>التاريخ</th><th>الإجمالي</th><th>الحالة</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td><a href="/Suppliers/OrderDetails/@o.Id">@o.OrderNumber</a></td>
                        <td>@o.Supplier?.Name</td>
                        <td>@o.OrderDate.ToString("yyyy-MM-dd")</td>
                        <td class="fw-bold">@o.Total.ToString("N0") ج.م</td>
                        <td>
                            @if (o.Status == "مستلم")
                            { <span class="badge bg-success">@o.Status</span> }
                            else if (o.Status == "معلق")
                            { <span class="badge bg-warning text-dark">@o.Status</span> }
                            else
                            { <span class="badge bg-secondary">@o.Status</span> }
                        </td>
                        <td><a href="/Suppliers/OrderDetails/@o.Id" class="btn btn-sm btn-outline-secondary">تفاصيل</a></td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">لا توجد أوامر شراء</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
