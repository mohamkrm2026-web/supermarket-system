@using SuperMarket.Services
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - سوبر ماركت</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link href="~/css/app.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-dark navbar-expand-lg px-3 mb-0" style="background:#1a6e3c">
    <a class="navbar-brand fw-bold" href="/Home">🛒 سوبر ماركت</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="nav">
        <ul class="navbar-nav me-auto">
            <li class="nav-item"><a class="nav-link" href="/Home">الرئيسية</a></li>
            @if (User.IsInRole("Admin") || User.IsInRole("كاشير"))
            {
                <li class="nav-item"><a class="nav-link" href="/Sales/Cashier">🖥️ كاشير</a></li>
                <li class="nav-item"><a class="nav-link" href="/Sales">المبيعات</a></li>
                <li class="nav-item"><a class="nav-link" href="/Customers">العملاء</a></li>
            }
            @if (User.IsInRole("مشاهدة فقط"))
            {
                <li class="nav-item"><a class="nav-link" href="/Sales">المبيعات</a></li>
                <li class="nav-item"><a class="nav-link" href="/Customers">العملاء</a></li>
                <li class="nav-item"><a class="nav-link" href="/Products">المنتجات</a></li>
                <li class="nav-item"><a class="nav-link" href="/Suppliers">الموردين</a></li>
                <li class="nav-item"><a class="nav-link" href="/Reports">التقارير</a></li>
            }
            @if (User.IsInRole("Admin") || User.IsInRole("مدير مخزن"))
            {
                <li class="nav-item"><a class="nav-link" href="/Products">المنتجات</a></li>
                <li class="nav-item"><a class="nav-link" href="/Suppliers">الموردين</a></li>
            }
            @if (User.IsInRole("Admin"))
            {
                <li class="nav-item"><a class="nav-link" href="/Reports">التقارير</a></li>
                <li class="nav-item"><a class="nav-link" href="/Users">👥 المستخدمين</a></li>
            }
        </ul>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white small">
                👤 @User.Identity?.Name
                <span class="badge bg-light text-dark ms-1">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</span>
            </span>
            <form method="post" action="/Account/Logout" class="m-0">
                <button class="btn btn-sm btn-outline-light">خروج</button>
            </form>
        </div>
    </div>
</nav>
@{
    int daysLeft = LicenseService.DaysRemaining();
}
@if (daysLeft <= 30 && daysLeft >= 0)
{
    <div class="alert alert-warning alert-dismissible mb-0 py-2 text-center rounded-0" style="font-size:13px;">
        <strong>⚠️ تنبيه:</strong> ترخيص البرنامج سينتهي خلال <strong>@daysLeft يوم</strong>
        (بتاريخ @LicenseService.GetExpiry().ToString("yyyy-MM-dd")) — يرجى التجديد قبل انتهاء المدة.
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}
<div class="container-fluid px-4 py-3">
    @RenderBody()
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
