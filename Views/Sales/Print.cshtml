@model SuperMarket.Models.Sale
@{
    ViewData["Title"] = "طباعة فاتورة";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>فاتورة @Model.InvoiceNumber</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Arial, sans-serif; background: #f5f5f5; direction: rtl; }

        .page { background: white; width: 80mm; margin: 20px auto; padding: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.15); }

        /* Header */
        .header { text-align: center; border-bottom: 2px dashed #333; padding-bottom: 10px; margin-bottom: 10px; }
        .header h1 { font-size: 20px; font-weight: bold; color: #1a6e3c; }
        .header .subtitle { font-size: 11px; color: #666; margin-top: 3px; }
        .invoice-num { font-size: 12px; font-weight: bold; margin-top: 6px; color: #333; }

        /* Info */
        .info { font-size: 11px; margin-bottom: 8px; }
        .info-row { display: flex; justify-content: space-between; padding: 2px 0; }
        .info-row span:first-child { color: #666; }
        .info-row span:last-child { font-weight: bold; }

        /* Items */
        .divider { border: none; border-top: 1px dashed #999; margin: 8px 0; }
        .items-header { display: flex; font-size: 10px; font-weight: bold; color: #666; padding: 3px 0; border-bottom: 1px solid #eee; }
        .item-row { display: flex; font-size: 11px; padding: 4px 0; border-bottom: 1px dotted #eee; }
        .col-name { flex: 1; }
        .col-qty  { width: 30px; text-align: center; }
        .col-price{ width: 45px; text-align: center; }
        .col-total{ width: 50px; text-align: left; font-weight: bold; }

        /* Totals */
        .totals { margin-top: 8px; font-size: 12px; }
        .total-row { display: flex; justify-content: space-between; padding: 3px 0; }
        .total-row.discount { color: #dc3545; }
        .total-row.grand { font-size: 15px; font-weight: bold; border-top: 2px solid #333; margin-top: 6px; padding-top: 6px; color: #1a6e3c; }

        /* Footer */
        .footer { text-align: center; margin-top: 14px; border-top: 2px dashed #333; padding-top: 10px; }
        .footer p { font-size: 11px; color: #666; margin: 2px 0; }
        .footer .thanks { font-size: 13px; font-weight: bold; color: #1a6e3c; }
        .barcode { font-family: monospace; font-size: 9px; color: #999; margin-top: 6px; letter-spacing: 2px; }

        /* Print */
        @@media print {
            body { background: white; }
            .page { box-shadow: none; margin: 0; width: 80mm; }
            .no-print { display: none !important; }
        }

        /* Screen only buttons */
        .screen-actions { text-align: center; margin: 16px auto; width: 80mm; display: flex; gap: 8px; }
        .btn { padding: 8px 20px; border: none; border-radius: 6px; cursor: pointer; font-size: 13px; flex: 1; }
        .btn-print { background: #1a6e3c; color: white; }
        .btn-whatsapp { background: #25D366; color: white; }
        .btn-close-btn { background: #6c757d; color: white; }
    </style>
</head>
<body>

<div class="screen-actions no-print">
    <button class="btn btn-print" onclick="window.print()">🖨️ طباعة</button>
    @if (Model.Customer?.Phone != null)
    {
        <button class="btn btn-whatsapp" onclick="sendWhatsApp()">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
            </svg>
            واتساب
        </button>
    }
    <button class="btn btn-close-btn" onclick="window.close()">✕ إغلاق</button>
</div>

<div class="page">
    <!-- Header -->
    <div class="header">
        <h1>🛒 سوبر ماركت</h1>
        <div class="subtitle">نظام إدارة المبيعات</div>
        <div class="invoice-num">@Model.InvoiceNumber</div>
    </div>

    <!-- Info -->
    <div class="info">
        <div class="info-row">
            <span>التاريخ:</span>
            <span>@Model.SaleDate.ToString("yyyy-MM-dd")</span>
        </div>
        <div class="info-row">
            <span>الوقت:</span>
            <span>@Model.SaleDate.ToString("HH:mm")</span>
        </div>
        <div class="info-row">
            <span>العميل:</span>
            <span>@(Model.Customer?.Name ?? "عميل عام")</span>
        </div>
        <div class="info-row">
            <span>الدفع:</span>
            <span>@Model.PaymentMethod</span>
        </div>
    </div>

    <hr class="divider">

    <!-- Items Header -->
    <div class="items-header">
        <div class="col-name">المنتج</div>
        <div class="col-qty">كمية</div>
        <div class="col-price">سعر</div>
        <div class="col-total">إجمالي</div>
    </div>

    <!-- Items -->
    @foreach (var item in Model.Items)
    {
        <div class="item-row">
            <div class="col-name">@item.ProductName</div>
            <div class="col-qty">@item.Quantity</div>
            <div class="col-price">@item.Price.ToString("N2")</div>
            <div class="col-total">@item.Total.ToString("N2")</div>
        </div>
    }

    <hr class="divider">

    <!-- Totals -->
    <div class="totals">
        <div class="total-row">
            <span>المجموع الفرعي:</span>
            <span>@Model.SubTotal.ToString("N2") ج.م</span>
        </div>
        @if (Model.Discount > 0)
        {
            <div class="total-row discount">
                <span>خصم:</span>
                <span>- @Model.Discount.ToString("N2") ج.م</span>
            </div>
        }
        <div class="total-row grand">
            <span>الإجمالي:</span>
            <span>@Model.Total.ToString("N2") ج.م</span>
        </div>
    </div>

    <!-- Footer -->
    <div class="footer">
        <p class="thanks">شكراً لتسوقكم معنا 🙏</p>
        <p>نرحب بزيارتكم مجدداً</p>
        <div class="barcode">@Model.InvoiceNumber</div>
    </div>
</div>

<script>
    // طباعة تلقائية عند فتح الصفحة
    window.onload = function() { window.print(); }

    function sendWhatsApp() {
        const phone = '@(Model.Customer?.Phone ?? "")'.replace(/[^0-9]/g, '');
        if (!phone) return;
        const intlPhone = phone.startsWith('0') ? '2' + phone : phone.startsWith('2') ? phone : '2' + phone;

        const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
            invoiceNumber = Model.InvoiceNumber,
            customerName  = Model.Customer?.Name ?? "عميل عام",
            date          = Model.SaleDate.ToString("yyyy-MM-dd HH:mm"),
            paymentMethod = Model.PaymentMethod,
            discount      = Model.Discount,
            total         = Model.Total,
            items         = Model.Items.Select(i => new {
                name     = i.ProductName,
                quantity = i.Quantity,
                total    = i.Total
            })
        }));

        let msg = `🛒 *سوبر ماركت - فاتورة مشترياتك*\n`;
        msg += `━━━━━━━━━━━━━━━━\n`;
        msg += `📋 رقم الفاتورة: *${data.invoiceNumber}*\n`;
        msg += `👤 العميل: ${data.customerName}\n`;
        msg += `📅 التاريخ: ${data.date}\n`;
        msg += `💳 طريقة الدفع: ${data.paymentMethod}\n`;
        msg += `━━━━━━━━━━━━━━━━\n`;
        msg += `*المشتريات:*\n`;
        data.items.forEach(i => {
            msg += `• ${i.name} × ${i.quantity} = ${i.total.toFixed(2)} ج.م\n`;
        });
        msg += `━━━━━━━━━━━━━━━━\n`;
        if (data.discount > 0) msg += `🎁 خصم: ${data.discount.toFixed(2)} ج.م\n`;
        msg += `💰 *الإجمالي: ${data.total.toFixed(2)} ج.م*\n`;
        msg += `━━━━━━━━━━━━━━━━\n`;
        msg += `🙏 شكراً لتسوقكم معنا!`;

        window.open(`https://wa.me/${intlPhone}?text=${encodeURIComponent(msg)}`, '_blank');
    }
</script>
</body>
</html>
