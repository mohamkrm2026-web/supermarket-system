@{
    ViewData["Title"] = "عميل جديد";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="card" style="max-width:500px;margin:auto">
    <div class="card-header"><h5 class="mb-0">إضافة عميل جديد</h5></div>
    <div class="card-body">
        <form method="post" action="/Customers/Create">
            <div class="mb-3">
                <label class="form-label fw-semibold">الاسم</label>
                <input type="text" name="Name" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">رقم الهاتف</label>
                <input type="text" name="Phone" class="form-control">
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">البريد الإلكتروني</label>
                <input type="email" name="Email" class="form-control">
            </div>
            <div class="d-flex gap-2 justify-content-end">
                <a href="/Customers" class="btn btn-outline-secondary">إلغاء</a>
                <button type="submit" class="btn btn-success">حفظ</button>
            </div>
        </form>
    </div>
</div>


