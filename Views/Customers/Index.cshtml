@{
    ViewData["Title"] = "العملاء";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <form method="get" class="d-flex gap-2">
            <input name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="بحث بالاسم أو الهاتف..." style="width:220px">
            <button type="submit" class="btn btn-sm btn-outline-primary">بحث</button>
        </form>
        <a href="/Customers/Create" class="btn btn-success btn-sm">+ عميل جديد</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0 small">
            <thead class="table-light">
                <tr><th>الاسم</th><th>الهاتف</th><th>إجمالي المشتريات</th><th>النقاط</th><th>تاريخ التسجيل</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td><strong>@c.Name</strong></td>
                        <td class="text-muted">@c.Phone</td>
                        <td class="text-success fw-bold">@c.TotalPurchases.ToString("N2")</td>
                        <td><span class="badge bg-warning text-dark">@c.Points نقطة</span></td>
                        <td class="text-muted">@c.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="/Customers/Details/@c.Id" class="btn btn-sm btn-outline-secondary">عرض</a>
                                <a href="/Customers/Edit/@c.Id" class="btn btn-sm btn-outline-primary">تعديل</a>
                                <form method="post" action="/Customers/Delete/@c.Id" style="display:inline"
                                      onsubmit="return confirm('حذف العميل؟')">
                                    <button class="btn btn-sm btn-outline-danger">حذف</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


