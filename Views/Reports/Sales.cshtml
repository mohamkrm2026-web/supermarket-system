@{
    ViewData["Title"] = "تقارير المبيعات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3 no-print">
    <div class="d-flex align-items-center gap-2">
        <a href="/Reports" class="btn btn-sm btn-outline-secondary">→ رجوع</a>
        <h5 class="mb-0">📊 تقارير المبيعات</h5>
    </div>
    <button class="btn btn-danger btn-sm" onclick="window.print()">🖨️ طباعة PDF</button>
</div>

<!-- فلتر التاريخ -->
<div class="card mb-4 no-print">
    <div class="card-body p-2">
        <form method="get" class="d-flex gap-2 align-items-center flex-wrap">
            <label class="form-label mb-0 small">من:</label>
            <input type="date" name="from" value="@ViewBag.From" class="form-control form-control-sm" style="width:160px">
            <label class="form-label mb-0 small">إلى:</label>
            <input type="date" name="to" value="@ViewBag.To" class="form-control form-control-sm" style="width:160px">
            <button class="btn btn-success btn-sm px-3">عرض</button>
            <a href="/Reports/Sales?from=@DateTime.Today.ToString("yyyy-MM-dd")&to=@DateTime.Today.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary btn-sm">اليوم</a>
            <a href="/Reports/Sales?from=@DateTime.Today.AddDays(-7).ToString("yyyy-MM-dd")&to=@DateTime.Today.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary btn-sm">أسبوع</a>
            <a href="/Reports/Sales?from=@(new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).ToString("yyyy-MM-dd"))&to=@DateTime.Today.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary btn-sm">هذا الشهر</a>
        </form>
    </div>
</div>

<!-- print header -->
<div class="print-only text-center mb-4">
    <h3>🛒 سوبر ماركت — تقرير المبيعات</h3>
    <p>الفترة: @ViewBag.From إلى @ViewBag.To | تاريخ الطباعة: @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</p>
</div>

<!-- KPIs -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-right:4px solid #1a6e3c">
            <div class="stat-label">إجمالي الإيراد</div>
            <div class="stat-value text-success">@ViewBag.TotalRevenue.ToString("N0")</div>
            <div class="stat-sub">ج.م</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-right:4px solid #198754">
            <div class="stat-label">إجمالي الأرباح</div>
            <div class="stat-value text-success">@ViewBag.TotalProfit.ToString("N0")</div>
            <div class="stat-sub">ج.م</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-right:4px solid #dc3545">
            <div class="stat-label">إجمالي الخصومات</div>
            <div class="stat-value text-danger">@ViewBag.TotalDiscount.ToString("N0")</div>
            <div class="stat-sub">ج.م</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-right:4px solid #6f42c1">
            <div class="stat-label">عدد الفواتير</div>
            <div class="stat-value">@ViewBag.TotalCount</div>
            <div class="stat-sub">فاتورة</div>
        </div>
    </div>
</div>

<!-- مقارنة الشهر -->
<div class="card mb-4">
    <div class="card-header"><strong>📅 مقارنة الأشهر</strong></div>
    <div class="card-body">
        <div class="row g-3 text-center">
            <div class="col-6">
                <div class="p-3 bg-light rounded">
                    <div class="small text-muted">هذا الشهر</div>
                    <div class="fs-4 fw-bold text-primary">@ViewBag.ThisMonthRevenue.ToString("N0") ج.م</div>
                </div>
            </div>
            <div class="col-6">
                <div class="p-3 bg-light rounded">
                    <div class="small text-muted">الشهر السابق</div>
                    <div class="fs-4 fw-bold text-secondary">@ViewBag.LastMonthRevenue.ToString("N0") ج.م</div>
                </div>
            </div>
        </div>
        @{
            decimal thisM = ViewBag.ThisMonthRevenue;
            decimal lastM = ViewBag.LastMonthRevenue;
            double pct = lastM > 0 ? Math.Round((double)(thisM - lastM) / (double)lastM * 100, 1) : 0;
            string pctClass = pct >= 0 ? "text-success" : "text-danger";
            string pctIcon = pct >= 0 ? "↑" : "↓";
        }
        <div class="text-center mt-2">
            <span class="fs-5 fw-bold @pctClass">@pctIcon @Math.Abs(pct)% @(pct >= 0 ? "نمو" : "انخفاض")</span>
            <span class="text-muted small"> مقارنة بالشهر السابق</span>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- ساعات الذروة -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><strong>⏰ ساعات الذروة</strong></div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 small">
                    <thead class="table-light"><tr><th>الساعة</th><th>عدد المبيعات</th><th>الإيراد</th></tr></thead>
                    <tbody>
                        @foreach (var h in (dynamic)ViewBag.PeakHours)
                        {
                            <tr>
                                <td>@h.Hour:00 — @(h.Hour+1):00</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-primary rounded" style="height:8px;width:@(h.Count * 10)px;max-width:80px"></div>
                                        @h.Count
                                    </div>
                                </td>
                                <td class="text-success fw-bold">@h.Total.ToString("N0")</td>
                            </tr>
                        }
                        @if (((System.Collections.IList)ViewBag.PeakHours).Count == 0)
                        {
                            <tr><td colspan="3" class="text-center text-muted py-3">لا توجد بيانات</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <!-- طرق الدفع -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><strong>💳 طرق الدفع</strong></div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 small">
                    <thead class="table-light"><tr><th>الطريقة</th><th>عدد</th><th>الإجمالي</th></tr></thead>
                    <tbody>
                        @foreach (var pm in (dynamic)ViewBag.PaymentMethods)
                        {
                            <tr>
                                <td class="fw-bold">@pm.Method</td>
                                <td>@pm.Count</td>
                                <td class="text-success fw-bold">@pm.Total.ToString("N0") ج.م</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- مبيعات يومية -->
<div class="card mb-4">
    <div class="card-header"><strong>📆 المبيعات اليومية</strong></div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0 small">
            <thead class="table-light"><tr><th>التاريخ</th><th>عدد الفواتير</th><th>الإجمالي</th></tr></thead>
            <tbody>
                @foreach (var d in (dynamic)ViewBag.DailySales)
                {
                    <tr>
                        <td>@d.Date.ToString("yyyy-MM-dd")</td>
                        <td>@d.Count</td>
                        <td class="fw-bold text-success">@d.Total.ToString("N2") ج.م</td>
                    </tr>
                }
                @if (((System.Collections.IList)ViewBag.DailySales).Count == 0)
                {
                    <tr><td colspan="3" class="text-center text-muted py-3">لا توجد مبيعات في هذه الفترة</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<style>
    @@media print {
        .no-print { display: none !important; }
        .print-only { display: block !important; }
        nav, footer { display: none !important; }
        .container-fluid { padding: 0 !important; }
    }
    .print-only { display: none; }
</style>
}
