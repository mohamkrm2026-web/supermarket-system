@{
    ViewData["Title"] = "تقارير الأرباح";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-3 no-print">
    <div class="d-flex align-items-center gap-2">
        <a href="/Reports" class="btn btn-sm btn-outline-secondary">→ رجوع</a>
        <h5 class="mb-0">💰 تقارير الأرباح</h5>
    </div>
    <button class="btn btn-danger btn-sm" onclick="window.print()">🖨️ طباعة PDF</button>
</div>

<div class="card mb-3 no-print">
    <div class="card-body p-2">
        <form method="get" class="d-flex gap-2 align-items-center flex-wrap">
            <label class="form-label mb-0 small">من:</label>
            <input type="date" name="from" value="@ViewBag.From" class="form-control form-control-sm" style="width:160px">
            <label class="form-label mb-0 small">إلى:</label>
            <input type="date" name="to" value="@ViewBag.To" class="form-control form-control-sm" style="width:160px">
            <button class="btn btn-success btn-sm px-3">عرض</button>
            <a href="/Reports/Profits?from=@(new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).ToString("yyyy-MM-dd"))&to=@DateTime.Today.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary btn-sm">هذا الشهر</a>
        </form>
    </div>
</div>

<div class="print-only text-center mb-4">
    <h3>🛒 سوبر ماركت — تقرير الأرباح</h3>
    <p>الفترة: @ViewBag.From إلى @ViewBag.To | تاريخ الطباعة: @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-right:4px solid #0d6efd">
            <div class="stat-label">إجمالي الإيراد</div>
            <div class="stat-value text-primary">@ViewBag.TotalRevenue.ToString("N0")</div>
            <div class="stat-sub">ج.م</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-right:4px solid #dc3545">
            <div class="stat-label">إجمالي التكلفة</div>
            <div class="stat-value text-danger">@ViewBag.TotalCost.ToString("N0")</div>
            <div class="stat-sub">ج.م</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-right:4px solid #1a6e3c">
            <div class="stat-label">صافي الربح</div>
            <div class="stat-value text-success">@ViewBag.TotalProfit.ToString("N0")</div>
            <div class="stat-sub">ج.م</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-right:4px solid #198754">
            <div class="stat-label">هامش الربح</div>
            <div class="stat-value text-success">@ViewBag.ProfitMargin%</div>
            <div class="stat-sub">من الإيراد</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- أكثر المنتجات ربحاً -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-success text-white"><strong>💎 أكثر المنتجات ربحاً</strong></div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 small">
                    <thead class="table-light"><tr><th>#</th><th>المنتج</th><th>الكمية</th><th>الربح</th></tr></thead>
                    <tbody>
                        @{ int r = 1; }
                        @foreach (var p in (dynamic)ViewBag.TopProfitable)
                        {
                            <tr>
                                <td><span class="badge bg-success">@r</span></td>
                                <td>@p.ProductName</td><td>@p.Qty</td>
                                <td class="text-success fw-bold">@p.TotalProfit.ToString("N2") ج.م</td>
                            </tr>
                            r++;
                        }
                        @if (((System.Collections.IList)ViewBag.TopProfitable).Count == 0)
                        { <tr><td colspan="4" class="text-center text-muted py-3">لا توجد بيانات</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <!-- ربح يومي -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><strong>📆 الربح اليومي</strong></div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 small">
                    <thead class="table-light"><tr><th>التاريخ</th><th>الإيراد</th><th>الربح</th></tr></thead>
                    <tbody>
                        @foreach (var d in (dynamic)ViewBag.DailyProfit)
                        {
                            <tr>
                                <td>@d.Date.ToString("yyyy-MM-dd")</td>
                                <td>@d.Revenue.ToString("N0")</td>
                                <td class="text-success fw-bold">@d.Profit.ToString("N2") ج.م</td>
                            </tr>
                        }
                        @if (((System.Collections.IList)ViewBag.DailyProfit).Count == 0)
                        { <tr><td colspan="3" class="text-center text-muted py-3">لا توجد بيانات</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- هامش ربح كل منتج -->
<div class="card">
    <div class="card-header"><strong>📊 هامش الربح لكل منتج</strong></div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0 small">
            <thead class="table-light"><tr><th>المنتج</th><th>الفئة</th><th>سعر التكلفة</th><th>سعر البيع</th><th>الربح/وحدة</th><th>هامش الربح</th></tr></thead>
            <tbody>
                @foreach (var p in (dynamic)ViewBag.ProductMargins)
                {
                    <tr>
                        <td class="fw-bold">@p.Name</td><td>@p.Category</td>
                        <td>@p.CostPrice.ToString("N2")</td><td>@p.Price.ToString("N2")</td>
                        <td class="text-success fw-bold">@p.Profit.ToString("N2") ج.م</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height:8px">
                                    <div class="progress-bar bg-success" style="width:@(Math.Min((double)p.Margin, 100))%"></div>
                                </div>
                                <span class="fw-bold text-success">@p.Margin%</span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<style>
    @@media print { .no-print{display:none!important;} .print-only{display:block!important;} nav{display:none!important;} .container-fluid{padding:0!important;} }
    .print-only{display:none;}
</style>
}
